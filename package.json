{
  "name": "@blundergoat/goat-flow",
  "version": "0.7.0",
  "description": "CLI auditor + scoring engine for GOAT Flow AI coding agent workflows",
  "type": "module",
  "bin": {
    "goat-flow": "./dist/cli/cli.js"
  },
  "exports": {
    ".": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "setup",
    "workflow"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "self-scan": "node dist/cli/cli.js .",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.6.0",
    "eslint": "^10.1.0",
    "knip": "^6.0.2",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.1"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "workflow",
    "audit",
    "claude",
    "codex",
    "gemini"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/blundergoat/goat-flow",
    "directory": "."
  }
}
